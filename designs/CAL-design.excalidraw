    {
      "id": "YtYhDluAIlzTEgslvSCTQ",
      "type": "text",
      "x": -2127.2475787030535,
      "y": -1868.7173101516019,
      "width": 517.0501098632812,
      "height": 770,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c1sL",
      "roundness": null,
      "seed": 844331328,
      "version": 1290,
      "versionNonce": 1079369789,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782023284621,
      "link": null,
      "locked": false,
      "text": "\nFor each block hash:\n   \n   1. Fibonacci hash chooses shard\n   \n   2. lookup blockHash in that shard\n   \n   3. get HostBitmap\n \n   4. learn which pods have that block\n   \n   if any entries exist:\n        return the cached pod\n    else :\n    add hash to the index\n    mark the pods as empty\n   \n\n\n     \n\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nFor each block hash:\n   \n   1. Fibonacci hash chooses shard\n   \n   2. lookup blockHash in that shard\n   \n   3. get HostBitmap\n \n   4. learn which pods have that block\n   \n   if any entries exist:\n        return the cached pod\n    else :\n    add hash to the index\n    mark the pods as empty\n   \n\n\n     \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
